    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.1",
    "firebase-admin": "^12.7.0",
    "jsonwebtoken": "^9.0.2",
