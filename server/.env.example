# Copy to .env and fill in values. Never commit .env with real credentials.

# MongoDB Atlas connection string (from MongoDB Atlas > Connect > Drivers)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/DATABASE?retryWrites=true&w=majority&appName=Cluster0

# Secret for JWT signing (use a long random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Comma-separated admin emails (these users can sign up at /admin/signup and access /admin)
ADMIN_EMAILS=mubarismuhammed33@gmail.com

# Contact form: messages are saved to DB and emailed to this address (default: first ADMIN_EMAILS)
CONTACT_TO_EMAIL=mubarismuhammed33@gmail.com

# Optional: SMTP to send contact form emails (if not set, messages are only saved to DB)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Model Management <your@gmail.com>

# Server port (default 3001)
PORT=3001
