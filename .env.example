# Next.js frontend: copy to .env.local

# Backend API URL (required in production when API is on another host, e.g. Render)
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# Optional: floating social buttons (right side)
# NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/yourpage
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/yourpage
# NEXT_PUBLIC_WHATSAPP_NUMBER=23012345678
